# Copia este archivo como .env y completa los valores reales.
# NUNCA commitear el archivo .env — ya está en .gitignore.

# URL base del Web Service en la nube (sin slash final)
CLOUD_BASE_URL=https://your-backend.onrender.com

# MAC address de este Edge Node tal como fue registrada en el backend
EDGE_MAC=AA:BB:CC:DD:EE:FF

# MAC address del dispositivo IoT sensor registrado en el backend
IOT_MAC=BB:CC:DD:EE:FF:AA

# API key para autenticación con el Web Service (dejar vacío si no aplica)
CLOUD_API_KEY=

# Timeout HTTP en segundos para requests al Web Service
CLOUD_TIMEOUT=10

# Ruta al archivo SQLite de datos locales
DATABASE_PATH=edge_data.db

# Activar modo debug de Flask (solo en desarrollo local)
FLASK_DEBUG=false
